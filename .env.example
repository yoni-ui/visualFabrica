# Admin sign-in (required in production). No quotes needed; trailing spaces are trimmed.
ADMIN_PASSWORD=adnmin

# JWT signing secret for vf_admin_session cookie (16+ chars; required in production)
ADMIN_AUTH_SECRET=generate-a-long-random-string-at-least-32-chars

# Optional: set to false only if the app is served over plain HTTP behind a proxy (default: secure cookies in production)
# ADMIN_COOKIE_SECURE=false
